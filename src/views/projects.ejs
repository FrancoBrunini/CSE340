<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <%= new Date(project.date).toLocaleDateString() %>:
                        <%= project.title %>
                            (<%= project.organization_name %>)
                </li>
                <% }); %>
        </ul>

    </main>

    <%- include('partials/footer') %>