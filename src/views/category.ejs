<%- include('partials/header') %>

<main>
    <h1><%= category.name %></h1>
    
    <% if (category.description) { %>
        <p><%= category.description %></p>
    <% } %>

    <h2>Service Projects in this Category</h2>

    <% if (projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <%= new Date(project.date).toLocaleDateString() %>: 
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a> 
                    (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No projects currently scheduled for this category.</p>
    <% } %>
</main>

<%- include('partials/footer') %>